# Cấu hình Token Telegram Bot gửi preview hồ sơ
TELEGRAM_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# Mật khẩu tài khoản eOffice đăng nhập tự động
EOFFICE_PASS=your_eoffice_password_here

# Đường dẫn vật lý đến thư mục chứa các tệp tin template và đầu ra (.docx, .pdf)
# - Trên Docker/Linux mặc định: /data
# - Trên Windows chạy local ví dụ: D:/n8n/ho_so_mua_sam
BASE_DATA_PATH=/data
